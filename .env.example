# =============================================
# GroupLeveling 环境变量模板
# 复制此文件为 .env 并修改对应值
# cp .env.example .env
# =============================================

# --- PostgreSQL ---
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=study_app
DB_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- App ---
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
GIN_MODE=debug
PORT=8080
